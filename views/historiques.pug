                .old-director
                    .photo
                        img(src="/img/avatar.png", alt="hassan", srcset="")
                    .info
                        h3 Directeur : 1994 - 1996 
                        p(class="text") Mr CHEICK OUMAR DIALLO
                .old-director
                    .photo
                        img(src="/img/avatar.png", alt="hama", srcset="")
                    .info
                        h3 Directeur : 1993 - 1994 
                        p(class="text") Mr HAMA EL HADJ MAIGA SIMBARA