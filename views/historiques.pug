                        p(class="text") Mr Youssouf MAIGA
                .chef-des-travaux
                    .photo
                        img(src="/img/avatar.png", alt="chef des travaux", srcset="")
                    .info
                        h2 Chef des travaux 
                        p(class="text") Mr Issiaka DOLO
                .econome
                    .photo
                        img(src="/img/avatar.png", alt="econome", srcset="")
