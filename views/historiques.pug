extends ./layout.pug
block content 
    .historiques-containers 
        h2(class="bigTittle") Historiques Space
        .historique-container 
            .directeur-actuel
                .photo
                    img(src="/img/avatar.png", alt="directeur actuel", srcset="")
                .info
                    h2 Direct Général 
                    p(class="text") Mr BRAHIMA H TIMBOLIBA
            .teams-container
                .directeur-des-etudes
                    .photo
                        img(src="/img/avatar.png", alt="directeur des études", srcset="")
